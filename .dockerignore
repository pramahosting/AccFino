# AccFino .dockerignore
# Based on .gitignore but explicitly INCLUDE the shipped database

# Node
node_modules/
react_frontend/dist/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# Logs / temp
*.log
*.tmp
.env

# Git
.git/
.gitignore

# OS
.DS_Store
Thumbs.db

# Session data (don't include user session files)
main_app/data/admin/
main_app/data/p/

# Keep: db_app/hsledger.db — this is the SHIPPED seed database
# Do NOT exclude it (override .gitignore behaviour)
!db_app/hsledger.db
